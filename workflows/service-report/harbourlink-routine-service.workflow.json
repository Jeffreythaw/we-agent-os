{
  "workflowId": "wf-hbl-routine-svc",
  "workflowName": "HarbourLink Routine Contract Service Report",
  "facts": {},
  "variables": {},
  "steps": [
    {
      "id": "step-1-validate",
      "skillId": "system.rule_check",
      "parameters": {
        "rules": [
          {
            "factKey": "projectCode",
            "operator": "exists",
            "severity": "error",
            "message": "Project Code is required."
          },
          {
            "factKey": "projectCode",
            "operator": "equals",
            "expectedValue": "HBL",
            "severity": "error",
            "message": "Project Code must be HBL."
          },
          {
            "factKey": "reportCategory",
            "operator": "equals",
            "expectedValue": "ROUTINE_CONTRACT_SERVICE",
            "severity": "error",
            "message": "Report Category must be ROUTINE_CONTRACT_SERVICE."
          },
          {
            "factKey": "client",
            "operator": "exists",
            "severity": "error",
            "message": "Client is required."
          },
          {
            "factKey": "equipment",
            "operator": "exists",
            "severity": "error",
            "message": "Equipment is required."
          },
          {
            "factKey": "serviceDate",
            "operator": "exists",
            "severity": "error",
            "message": "Service Date is required."
          },
          {
            "factKey": "referenceNo",
            "operator": "regex",
            "expectedValue": "^SVC/HBL/\\d{6}/\\d{3}$",
            "severity": "error",
            "message": "Reference Number must match SVC/HBL/MMYYYY/NNN format."
          },
          {
            "factKey": "workDescription",
            "operator": "exists",
            "severity": "error",
            "message": "Work Description is required."
          },
          {
            "factKey": "findings",
            "operator": "exists",
            "severity": "error",
            "message": "Findings are required."
          },
          {
            "factKey": "photoCaptions",
            "operator": "exists",
            "severity": "error",
            "message": "Photo Captions are required."
          },
          {
            "factKey": "finalOperatingCondition",
            "operator": "exists",
            "severity": "error",
            "message": "Final Operating Condition is required."
          }
        ]
      }
    },
    {
      "id": "step-2-qa",
      "skillId": "system.checklist_check",
      "parameters": {
        "checklist": {
          "id": "cl-hbl-qa",
          "name": "HarbourLink QA Checklist",
          "items": [
            {
              "id": "item-1-tech",
              "label": "Technician Name Valid",
              "required": true,
              "rule": {
                "factKey": "technicianName",
                "operator": "exists",
                "severity": "error",
                "message": "Technician Name is required for signoff."
              }
            },
            {
              "id": "item-2-rec",
              "label": "Recommendations Provided",
              "required": false,
              "rule": {
                "factKey": "recommendations",
                "operator": "exists",
                "severity": "warning",
                "message": "Recommendations should ideally be provided."
              }
            }
          ]
        }
      }
    },
    {
      "id": "step-3-render",
      "skillId": "system.template_render",
      "parameters": {
        "template": "<!DOCTYPE html>\n<html>\n<head>\n<style>\nbody { font-family: 'Helvetica', sans-serif; color: #333; }\n.header { border-bottom: 2px solid #005f99; padding-bottom: 10px; }\n.section-title { color: #005f99; margin-top: 20px; }\ntable { width: 100%; border-collapse: collapse; }\nth, td { padding: 8px; border: 1px solid #ddd; text-align: left; }\n.signature-block { margin-top: 40px; width: 100%; }\n.sig-box { width: 30%; display: inline-block; padding-top: 50px; border-top: 1px solid #333; text-align: center; margin-right: 3%; }\n</style>\n</head>\n<body>\n<div class=\"header\">\n<h1>HarbourLink Service Report</h1>\n<p><strong>Reference Number:</strong> {{referenceNo}}</p>\n</div>\n<table>\n<tr><th>Project</th><td>{{projectCode}}</td><th>Client</th><td>{{client}}</td></tr>\n<tr><th>Date</th><td>{{serviceDate}}</td><th>Technician</th><td>{{technicianName}}</td></tr>\n<tr><th>Equipment</th><td colspan=\"3\">{{equipment}}</td></tr>\n</table>\n<h2 class=\"section-title\">Work Description</h2>\n<p>{{workDescription}}</p>\n<h2 class=\"section-title\">Findings</h2>\n<p>{{findings}}</p>\n<h2 class=\"section-title\">Recommendations</h2>\n<p>{{recommendations}}</p>\n<h2 class=\"section-title\">Photos</h2>\n<p>{{photoCaptions}}</p>\n<h2 class=\"section-title\">Final Operating Condition</h2>\n<p>{{finalOperatingCondition}}</p>\n\n<h2 class=\"section-title\">Signatures & Acknowledgement</h2>\n<div class=\"signature-block\">\n<div class=\"sig-box\"><p>Prepared By:<br>{{preparedBy}}</p></div>\n<div class=\"sig-box\"><p>Checked By:<br>{{checkedBy}}</p></div>\n<div class=\"sig-box\"><p>Client Representative:<br>{{clientRepresentative}}<br>Date: {{clientAcknowledgementDate}}</p></div>\n</div>\n</body>\n</html>\n"
      }
    }
  ]
}
